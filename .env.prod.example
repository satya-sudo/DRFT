POSTGRES_DB=drft
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DRFT_POSTGRES_DATA_PATH=./data/postgres
DRFT_STORAGE_PATH=./data/storage
DRFT_BACKUPS_PATH=./backups

DRFT_IMAGE_TAG=latest
DRFT_APP_ENV=production
DRFT_DB_DSN=postgres://postgres:postgres@postgres:5432/drft?sslmode=disable
DRFT_JWT_SECRET=change-me
DRFT_MAX_UPLOAD_SIZE_BYTES=1073741824
DRFT_UPLOAD_SESSION_TTL_HOURS=24
DRFT_API_PORT=8080
DRFT_WEB_PORT=3000
DRFT_BACKUP_INTERVAL_HOURS=24
DRFT_BACKUP_RETENTION_DAYS=7
DRFT_BACKUP_RUN_ON_START=true

DRFT_SMTP_HOST=
DRFT_SMTP_PORT=
DRFT_SMTP_USERNAME=
DRFT_SMTP_PASSWORD=
DRFT_SMTP_FROM_EMAIL=
DRFT_SMTP_FROM_NAME=DRFT
DRFT_PASSWORD_RESET_TTL_MINUTES=10
